<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <system.webServer>
        <!-- Deny all access to storage directory -->
        <security>
            <requestFiltering>
                <hiddenSegments>
                    <add segment="storage" />
                </hiddenSegments>
            </requestFiltering>
        </security>
        
        <!-- Custom error for denied access -->
        <httpErrors errorMode="Custom">
            <remove statusCode="404" subStatusCode="8" />
            <error statusCode="404" subStatusCode="8" 
                   responseMode="ExecuteURL" 
                   path="/error.php" />
        </httpErrors>
        
        <!-- Deny access to all files -->
        <handlers>
            <clear />
        </handlers>
        
        <!-- Additional security -->
        <directoryBrowse enabled="false" />
    </system.webServer>
</configuration>
