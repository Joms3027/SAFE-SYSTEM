<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <system.webServer>
        <!-- Deny all access to log files -->
        <security>
            <requestFiltering>
                <hiddenSegments>
                    <add segment="logs" />
                </hiddenSegments>
                <fileExtensions>
                    <add fileExtension=".log" allowed="false" />
                </fileExtensions>
            </requestFiltering>
        </security>
        
        <!-- Disable all handlers -->
        <handlers>
            <clear />
        </handlers>
        
        <!-- Disable directory browsing -->
        <directoryBrowse enabled="false" />
    </system.webServer>
</configuration>
