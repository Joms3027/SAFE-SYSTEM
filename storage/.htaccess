# Protect storage directory
# Deny all web access to storage files
# Compatible with Apache 2.2 and 2.4+

# Prevent directory listing
Options -Indexes

# Deny all access (Apache 2.4+)
<IfModule mod_authz_core.c>
    Require all denied
</IfModule>

# Deny all access (Apache 2.2)
<IfModule !mod_authz_core.c>
    Order Deny,Allow
    Deny from all
</IfModule>

# Block all file types
<FilesMatch ".*">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order Allow,Deny
        Deny from all
    </IfModule>
</FilesMatch>
