# Protect database directory
# Deny all web access to database files and migrations

# Deny all access
Order Deny,Allow
Deny from all

# Prevent directory listing
Options -Indexes

# Block access to all database-related files
<FilesMatch "\.(sql|db|sqlite|sqlite3|mdb|accdb|bak|backup)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# Block all PHP files in db directory
<FilesMatch "\.php$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# Block access to all files
<FilesMatch ".*">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# Prevent access to hidden files
<FilesMatch "^\.">
    Order Allow,Deny
    Deny from all
</FilesMatch>

