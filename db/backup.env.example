# Database Backup Credentials
# Copy this file to backup.env and fill in your values.
# Used when Task Scheduler runs (system env vars may not be available).
# Add backup.env to .gitignore - never commit credentials!

DB_HOST=localhost
DB_NAME=wpu_faculty_system
DB_USER=root
DB_PASS=

# Optional: Path to mysqldump if not in system PATH
# MYSQLDUMP_PATH=C:\Program Files\MySQL\MySQL Server 8.0\bin\mysqldump.exe

# Optional: Retention in hours (default: 48)
# BACKUP_RETENTION_HOURS=48
