# Protect includes directory
# Allow API files to be accessed directly (they handle their own authentication)
# Deny all other PHP files

# For Apache 2.4+ (most common)
<IfModule mod_authz_core.c>
    # Allow API files explicitly
    <Files "notifications_api.php">
        Require all granted
    </Files>
    <Files "chat_api.php">
        Require all granted
    </Files>
    
    # Deny other PHP files by matching them individually
    # We can't use FilesMatch with exclusion, so we deny all PHP files
    # and then re-allow the API files (order matters - last rule wins)
    <FilesMatch "\.php$">
        Require all denied
    </FilesMatch>
    
    # Re-allow API files (this overrides the deny above)
    <Files "notifications_api.php">
        Require all granted
    </Files>
    <Files "chat_api.php">
        Require all granted
    </Files>
</IfModule>

# For Apache 2.2 (fallback)
<IfModule !mod_authz_core.c>
    # Allow API files explicitly
    <Files "notifications_api.php">
        Order Allow,Deny
        Allow from all
    </Files>
    <Files "chat_api.php">
        Order Allow,Deny
        Allow from all
    </Files>
    
    # Deny other PHP files
    <FilesMatch "\.php$">
        Order Deny,Allow
        Deny from all
    </FilesMatch>
    
    # Re-allow API files (this overrides the deny above)
    <Files "notifications_api.php">
        Order Allow,Deny
        Allow from all
    </Files>
    <Files "chat_api.php">
        Order Allow,Deny
        Allow from all
    </Files>
</IfModule>

# Block access to sensitive files
<FilesMatch "\.(htaccess|htpasswd|ini|log|sql|md|bak|config|dist|env|txt)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order Allow,Deny
        Deny from all
    </IfModule>
</FilesMatch>

# Prevent directory listing
Options -Indexes

# Prevent access to hidden files
<FilesMatch "^\.">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order Allow,Deny
        Deny from all
    </IfModule>
</FilesMatch>
