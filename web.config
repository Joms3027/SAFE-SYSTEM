<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- Prevent IIS from replacing API 401/403 with HTML error pages (fixes EventSource MIME type error) -->
    <location path="includes">
        <system.webServer>
            <httpErrors errorMode="Detailed" existingResponse="PassThrough" />
        </system.webServer>
    </location>
    <system.web>
        <httpRuntime executionTimeout="300" maxRequestLength="51200" />
    </system.web>
    <system.webServer>
        <!-- Increased timeout for batch uploads -->
        <security>
            <requestFiltering>
                <!-- Allow larger file uploads (50MB) for batch operations -->
                <requestLimits maxAllowedContentLength="52428800" />
                <!-- Block direct HTTP access to sensitive directories -->
                <hiddenSegments>
                    <add segment="storage" />
                    <add segment="db" />
                </hiddenSegments>
            </requestFiltering>
        </security>
        
        <!-- Default document - index.php is now our front controller -->
        <defaultDocument>
            <files>
                <clear />
                <add value="index.php" />
            </files>
        </defaultDocument>
        
        <!-- Directory browsing off -->
        <directoryBrowse enabled="false" />
        
        <!-- Security headers -->
        <httpProtocol>
            <customHeaders>
                <remove name="X-Powered-By" />
                <add name="X-Frame-Options" value="SAMEORIGIN" />
                <add name="X-Content-Type-Options" value="nosniff" />
                <add name="X-XSS-Protection" value="1; mode=block" />
                <add name="Referrer-Policy" value="strict-origin-when-cross-origin" />
                <!-- camera=(self) required for timekeeper QR scanner; geolocation/microphone stay restricted -->
                <add name="Permissions-Policy" value="geolocation=(), microphone=(), camera=(self)" />
            </customHeaders>
        </httpProtocol>
        
        <!-- Enable static and dynamic compression -->
        <urlCompression doStaticCompression="true" doDynamicCompression="true" />
        <httpCompression>
            <dynamicTypes>
                <add mimeType="application/json" enabled="true" />
                <add mimeType="application/json; charset=utf-8" enabled="true" />
            </dynamicTypes>
        </httpCompression>
        
        <!-- Static file caching -->
        <staticContent>
            <clientCache cacheControlMode="UseMaxAge" cacheControlMaxAge="30.00:00:00" />
            <remove fileExtension=".woff" />
            <remove fileExtension=".woff2" />
            <mimeMap fileExtension=".woff" mimeType="font/woff" />
            <mimeMap fileExtension=".woff2" mimeType="font/woff2" />
        </staticContent>
        
        <!-- URL Rewrite rules -->
        <rewrite>
            <rules>
                <!-- Block access to sensitive files and directories -->
                <rule name="Block Sensitive Files" stopProcessing="true">
                    <match url="(^storage/|^db/|\.sql$|\.log$|\.env$|\.ini$|\.htaccess$)" ignoreCase="true" />
                    <action type="CustomResponse" statusCode="403" statusReason="Forbidden" statusDescription="Access denied" />
                </rule>
                <!-- Allow static files to be served directly without rewriting -->
                <rule name="Static Files" stopProcessing="true">
                    <match url="\.(jpg|jpeg|png|gif|ico|css|js|woff|woff2|ttf|svg|pdf|mp3|docx|doc)$" ignoreCase="true" />
                    <action type="None" />
                </rule>
                
                <!-- Allow direct URL access to NACS scanner (no redirect) -->
                <rule name="Allow NACS Direct Access" stopProcessing="true">
                    <match url="^assets/js/NACS/.*\.php$" ignoreCase="true" />
                    <action type="None" />
                </rule>
                
                <!-- Redirect .php extension to clean URL (external redirect) -->
                <!-- This ensures URLs don't show .php in the browser address bar -->
                <rule name="Remove PHP Extension" stopProcessing="true">
                    <match url="^(.*)\.php$" ignoreCase="true" />
                    <conditions logicalGrouping="MatchAll">
                        <add input="{REQUEST_METHOD}" pattern="^GET$" />
                        <add input="{REQUEST_FILENAME}" matchType="IsFile" />
                    </conditions>
                    <action type="Redirect" url="{R:1}" redirectType="Permanent" />
                </rule>
                
                <!-- Internal rewrite: Add .php extension if file exists -->
                <rule name="Add PHP Extension" stopProcessing="true">
                    <match url="^(.*)$" ignoreCase="true" />
                    <conditions logicalGrouping="MatchAll">
                        <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
                        <add input="{REQUEST_FILENAME}" matchType="IsDirectory" negate="true" />
                        <add input="{REQUEST_FILENAME}.php" matchType="IsFile" />
                    </conditions>
                    <action type="Rewrite" url="{R:1}.php" />
                </rule>
                
                <!-- Front Controller - only if no file/directory found -->
                <rule name="Front Controller" stopProcessing="true">
                    <match url="^(.*)$" ignoreCase="true" />
                    <conditions logicalGrouping="MatchAll">
                        <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
                        <add input="{REQUEST_FILENAME}" matchType="IsDirectory" negate="true" />
                    </conditions>
                    <action type="Rewrite" url="index.php" />
                </rule>
            </rules>
        </rewrite>
    </system.webServer>
</configuration>
